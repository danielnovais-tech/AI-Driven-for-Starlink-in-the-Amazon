      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(throughput_mbps_sum[5m]) / rate(throughput_mbps_count[5m])",
          "legendFormat": "Mean Throughput",
          "refId": "A"
        }
      ],
      "title": "Mean Throughput (5-min avg)",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "dB", "min": -10, "max": 30 },
