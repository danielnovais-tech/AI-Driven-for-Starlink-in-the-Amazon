      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "snr_db",
          "legendFormat": "SNR",
          "refId": "A"
        }
      ],
      "title": "Current SNR (dB)",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
